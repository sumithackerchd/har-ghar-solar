# ============================================================
# Har Ghar Solar — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-strong-secret-key-here

# Database URL (SQLite default; change for production PostgreSQL)
DATABASE_URL=sqlite:///solar.db

# Email notifications (optional — leave blank to disable)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
ADMIN_EMAIL=admin@hargharsolar.in

# Server port (used when running locally)
PORT=5000
